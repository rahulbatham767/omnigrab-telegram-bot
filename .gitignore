# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
backend/node_modules/

# ── Build output ───────────────────────────────────────────────────────────────
frontend/dist/
frontend/.vite/

# ── Local binaries (yt-dlp, ffmpeg, node — installed separately on server) ────
bin/

# ── Server runtime artefacts ──────────────────────────────────────────────────
backend/bin/
backend/downloads/
backend/cache/
backend/*.mp4
backend/*.webm
backend/*.mkv
backend/*.mp3
backend/*.m4a
backend/*.opus
backend/*.flac

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Deploy script outputs (generated on server, not in repo) ──────────────────
/etc/
/opt/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo
*.orig

# ── Vite / Rollup cache ───────────────────────────────────────────────────────
.vite/
vite.config.js.timestamp-*

# ── package-lock / yarn (keep one, ignore the other if using npm) ─────────────
# Uncomment if you use yarn exclusively:
# package-lock.json

# ── Cloudflared ───────────────────────────────────────────────────────────────
*.json.bak
tunnel-config.yml
